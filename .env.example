# Copy to .env and fill in real values (never commit .env).

# Django
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (dj-database-url format). Defaults to local SQLite if unset.
DATABASE_URL=sqlite:///db.sqlite3

# Cloudinary — annotation image storage (leave blank to use local media)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=TaskCanvas
